{
  "name": "vocab-nest-be",
  "private": true,
  "version": "0.1.0",
  "description": "VocabNest Express API backend.",
  "packageManager": "pnpm@10.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "pnpm prisma:generate && tsc",
    "start": "node dist/server.js",
    "lint": "eslint src tests prisma prisma.config.ts vitest.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm prisma:generate && tsc --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "prisma db seed",
    "generate:api": "tsx src/openapi/write-openapi.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest",
    "bcrypt": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "express-rate-limit": "latest",
    "helmet": "latest",
    "jsonwebtoken": "latest",
    "morgan": "latest",
    "openai": "latest",
    "pg": "latest",
    "swagger-ui-express": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/bcrypt": "latest",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/morgan": "latest",
    "@types/node": "latest",
    "@types/pg": "latest",
    "@types/supertest": "latest",
    "@types/swagger-ui-express": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "prisma": "latest",
    "supertest": "latest",
    "tsx": "latest",
    "typescript": "^5",
    "typescript-eslint": "latest",
    "vitest": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma"
    ]
  }
}
