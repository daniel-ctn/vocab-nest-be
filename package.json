{
  "name": "vocabnest",
  "private": true,
  "version": "0.1.0",
  "description": "VocabNest Express API monorepo with shared contracts.",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --filter @vocabnest/contracts build && pnpm --filter @vocabnest/api dev",
    "generate:api": "pnpm --filter @vocabnest/api generate:openapi",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter @vocabnest/contracts typecheck && pnpm --filter @vocabnest/api typecheck",
    "test": "pnpm --filter @vocabnest/api test"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "typescript": "^5",
    "typescript-eslint": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma"
    ]
  }
}
